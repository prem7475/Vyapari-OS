{
  "name": "vyapari-os",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:api": "npm --workspace services/api run dev",
    "dev:ai": "npm --workspace services/ai run dev",
    "lint:web": "npm --workspace apps/web run lint",
    "lint:admin": "npm --workspace apps/admin run lint",
    "lint:api": "npm --workspace services/api run lint"
  }
}

